      "decisionStrategy": "UNANIMOUS",
      "config": {
        "defaultResourceType": "urn:secret-backend:resources:default",
        "applyPolicies": "[\"Default Policy\"]"
      }
    },
    {
      "name": "testrole-permission",
      "description": "",
